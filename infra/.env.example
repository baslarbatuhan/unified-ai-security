# infra/.env.example
# ────────────────────────────────────────────────────────────────────
# Copy to `infra/.env` and fill in the values you need:
#
#     cp infra/.env.example infra/.env
#
# `infra/.env` is git-ignored. Compose reads this file automatically when
# you run `docker compose up` from the `infra/` directory (or with
# `docker compose -f infra/docker-compose.yml up` from anywhere — the
# convention is "env file lives next to the compose file").
#
# Every variable is optional; the gateway boots and the dashboard works
# without secrets. You only need a value when:
#   - HF_TOKEN          → faster Hugging Face downloads / rate-limit relief
#   - OPENAI_API_KEY    → registering an OpenAI target via the dashboard
#   - ANTHROPIC_API_KEY → registering an Anthropic target via the dashboard
#   - GATEWAY_URL       → dashboard talking to a non-default gateway

# ── Hugging Face Hub ────────────────────────────────────────────────
# https://huggingface.co/settings/tokens — read-scope is enough.
HF_TOKEN=

# ── Target-side credentials ─────────────────────────────────────────
# These are forwarded to the gateway container and read by APIAdapter
# when a target is configured with `auth.token_env=<name>`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CHATBOT_BEARER_TOKEN=

# ── Dashboard wiring (rarely changed) ───────────────────────────────
# Default `http://gateway:8000` works for the in-network case.
# Override only if the dashboard should hit a host-side gateway:
#   GATEWAY_URL=http://host.docker.internal:8000
GATEWAY_URL=
GATEWAY_TIMEOUT_S=120
